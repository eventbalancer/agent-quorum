#!/usr/bin/env bash
# Auth-probe stub: must exit before any argv logging or prompt capture so
# preflight probes never pollute provider-call fixtures.
if [[ "${1:-}" == "login" && "${2:-}" == "status" ]]; then
  exit "${FAKE_CODEX_LOGIN_STATUS:-0}"
fi
if [[ -n "${FAKE_CODEX_ARGS_LOG:-}" ]]; then
  printf '%s\n' "$*" >> "$FAKE_CODEX_ARGS_LOG"
fi
if [[ -n "${FAKE_CODEX_ARGV_LOG:-}" ]]; then
  { for arg in "$@"; do printf '%s\0' "$arg"; done; printf '\036'; } >> "$FAKE_CODEX_ARGV_LOG"
fi
# Raw-stderr injection: one raw stdout NDJSON line, then a multi-line stderr
# blob plus one ~2 MB line with no trailing newline, then a non-zero exit.
# Exercises bounded capture + default-drop and the opt-in raw artifact.
if [[ -n "${FAKE_CODEX_STDERR:-}" ]]; then
  printf '{"type":"item.started","item":{"type":"command_execution","command":"/bin/zsh -lc \\"echo diag\\"","status":"in_progress","exit_code":null}}\n'
  printf 'raw codex stderr alpha: %s\n' "$FAKE_CODEX_STDERR" >&2
  printf 'raw codex stderr beta: overloaded request\n' >&2
  head -c 2000000 /dev/zero | tr '\0' 'x' >&2
  exit "${FAKE_CODEX_STDERR_EXIT:-1}"
fi
# Transient-failure injection: fail the first FAKE_CODEX_FAILS attempts (counted
# in FAKE_CODEX_ATTEMPTS) before any output, exercising provider_run retries.
if [[ -n "${FAKE_CODEX_ATTEMPTS:-}" ]]; then
  attempts=0
  [[ -f "$FAKE_CODEX_ATTEMPTS" ]] && attempts="$(cat "$FAKE_CODEX_ATTEMPTS")"
  attempts=$((attempts + 1))
  printf '%s' "$attempts" > "$FAKE_CODEX_ATTEMPTS"
  if (( attempts <= ${FAKE_CODEX_FAILS:-0} )); then
    echo "codex transient failure" >&2
    exit 1
  fi
fi
[[ "${1:-}" == "exec" ]] && shift
mode="fresh"
if [[ "${1:-}" == "resume" ]]; then
  mode="resume"
  shift
fi
out=""
prompt=""
session_id=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o|--output-last-message)
      out="$2"; shift 2 ;;
    --)
      shift; prompt="${1:-}"; break ;;
    -m|-c|--output-schema|--sandbox)
      shift 2 ;;
    --skip-git-repo-check|--color|--json)
      if [[ "$1" == "--color" && -n "${2:-}" && "${2:0:1}" != "-" ]]; then
        shift 2
      else
        shift
      fi ;;
    *)
      if [[ "$mode" == "resume" && -z "$session_id" ]]; then
        session_id="$1"
      else
        prompt="$1"
      fi
      shift ;;
  esac
done
[[ -n "$out" ]] || exit 2
if [[ "$prompt" == "-" ]]; then
  prompt="$(cat)"
fi
printf '%s' "$prompt" > "${FAKE_CODEX_PROMPT:?}"
output="${FAKE_CODEX_OUTPUT:-}"
if [[ -n "${FAKE_CODEX_OUTPUT_CALLS:-}" ]]; then
  calls=0
  [[ -f "$FAKE_CODEX_OUTPUT_CALLS" ]] && calls="$(cat "$FAKE_CODEX_OUTPUT_CALLS")"
  calls=$((calls + 1))
  printf '%s' "$calls" > "$FAKE_CODEX_OUTPUT_CALLS"
  var="FAKE_CODEX_OUTPUT_$calls"
  output="${!var:-$output}"
fi
[[ -n "$output" ]] || exit 2
cp "$output" "$out"
# Body-bearing stdout NDJSON: a tool input, assistant prose, an exec command,
# and a retry reason all carrying a planted body, to drive stdout redaction.
if [[ -n "${FAKE_CODEX_STDOUT_BODY:-}" ]]; then
  b="$FAKE_CODEX_STDOUT_BODY"
  printf '{"type":"assistant","message":{"content":[{"type":"tool_use","name":"Bash","input":{"command":"cat %s"}}]}}\n' "$b"
  printf '{"type":"assistant","message":{"content":[{"type":"text","text":"the plan body is %s"}]}}\n' "$b"
  printf '{"type":"item.started","item":{"type":"command_execution","command":"/bin/zsh -lc \\"echo %s\\"","status":"in_progress","exit_code":null}}\n' "$b"
  printf '{"type":"system","subtype":"api_retry","attempt":1,"max_retries":3,"delay_ms":10,"error":"failed: %s"}\n' "$b"
fi
if [[ -n "${FAKE_CODEX_EMIT_ID:-}" ]]; then
  printf '{"type":"thread.started","thread_id":"%s"}\n' "$FAKE_CODEX_EMIT_ID"
fi
if [[ -n "${FAKE_CODEX_STREAM_EVENTS:-}" ]]; then
  printf '{"type":"item.started","item":{"type":"command_execution","command":"/bin/zsh -lc \\"echo fixture\\"","status":"in_progress","exit_code":null}}\n'
  if [[ "$FAKE_CODEX_STREAM_EVENTS" == "failed" ]]; then
    printf '{"type":"item.completed","item":{"type":"command_execution","command":"/bin/zsh -lc \\"false\\"","status":"completed","exit_code":1}}\n'
  fi
elif [[ -z "${FAKE_CODEX_EMIT_ID:-}" ]]; then
  printf 'tokens used\n1\n'
fi
