#!/usr/bin/env bash
if [[ "${1:-}" == "exec" && "${2:-}" == "node" ]]; then
  printf '00000000-0000-4000-8000-%012d\n' "$$"
  exit 0
fi
if [[ "${1:-}" == "exec" && "${2:-}" == "ajv" ]]; then
  shift 2
  [[ "${1:-}" == "help" ]] && exit 0
  if [[ "${1:-}" == "validate" ]]; then
    shift
    schema=""
    data=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        -s)
          schema="$2"; shift 2 ;;
        -d)
          data="$2"; shift 2 ;;
        --spec|--strict)
          shift 2 ;;
        *)
          shift ;;
      esac
    done
    [[ -n "$schema" && -n "$data" ]] || exit 2
    jq -e --slurpfile doc "$data" '
      (.required // []) as $required |
      ($doc[0]) as $data |
      all($required[]?; . as $key | ($data | has($key)) and ($data[$key] != null))
    ' "$schema" >/dev/null
    exit $?
  fi
  exit 0
fi
exit 0
